void AlertTask::Task(void* parameters)
{
    uint32_t value;
    Buzzer_class buz;

    buz.buzzer_init();

    while(1)
    {
        xTaskNotifyWait( 0,0xFFFFFFFF, &value,0);




        HAL_GPIO_TogglePin(GPIOD,GPIO_PIN_14);
//        buz.beep_low();
        if(value==ALERT_NURSE)
        {
            buz.beep_low();
        }

        else if(value==ALERT_EMERGENCY)
        {
            buz.beep_high();
        }
    }
}


