#include<cstdint>
#include "stm32f405xx.h"
enum class led:uint8_t
{
	GREEN=12,
	ORANGE,
	RED,
	BLUE,
};

class GPIOClockGuard
{
public:
    GPIOClockGuard()
    {
        RCC->AHB1ENR |= (1U << 3); // Enable GPIOD
        RCC->AHB1ENR |= (1U << 0); // Enable GPIOA

    }

    ~GPIOClockGuard()
    {
        RCC->AHB1ENR &= ~(1U << 3); // Disable GPIOD
        RCC->AHB1ENR &= ~(1U << 0); // Disable GPIOA

    }
};


class GPIO
{
public:
    static void set_output(volatile std::uint32_t& moder, std::uint8_t pin)
    {
        moder &= ~(3U << (pin * 2));
        moder |=  (1U << (pin * 2)); // Output mode
    }

    static void set_input(volatile std::uint32_t& moder, std::uint8_t pin)
    {
        moder &= ~(3U << (pin * 2)); // Input mode (00)
    }

    static void toggle(volatile std::uint32_t& odr, std::uint8_t pin)
    {
        odr ^= (1U << pin);
    }

    static bool read(volatile std::uint32_t& idr, std::uint8_t pin)
    {
        return (idr & (1U << pin))!=0;
    }
};

