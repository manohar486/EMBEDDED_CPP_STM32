extern "C" void EXTI0_IRQHandler(void)
{
    if (EXTI->PR & (1 << 0))
    {
        button_count++;

        if(button_ptr)
        {
            button_ptr->notifyObservers();
        }

        EXTI->PR |= (1 << 0); // clear pending
    }
}
