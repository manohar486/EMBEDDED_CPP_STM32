{
	GPIOClockGuard obj;

	GPIO::set_output(GPIOD->MODER,12);
	GPIO::set_input(GPIOA->MODER, 0);


	while(true)
	{

		if(GPIO::read(GPIOA->IDR &(1<<0)))
		{
			break;
		}

	   GPIO::toggle(GPIOD->ODR, 12);
	   delay();
	}
