int main()
{

	Gpio_init();

	GreenLed G1(GPIOD,12);
	OrangeLed O1(GPIOD,13);
	RedLed R1(GPIOD,14);
	BlueLed B1(GPIOD,15);

	subject obj;
	obj.attach(&G1);
	obj.attach(&O1);
	obj.attach(&R1);
	obj.attach(&B1);

	while(1)
	{
		obj.poll();
	}

}


