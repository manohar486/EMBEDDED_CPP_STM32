void AlertTask::Task(void* parameters)
{
    uint32_t value;
    Buzzer_class buz;

    buz.buzzer_init();

    while(1)
    {
        xTaskNotifyWait( 0,0xFFFFFFFF, &value,0);

//        buz.beep_low();
        if(value==ALERT_NURSE)
        {
            buz.beep_low();
        }

        else if(value==ALERT_EMERGENCY)
        {
            buz.beep_high();
        }
    }
}

void DebugTask::Task(void* parameters)
{
	char buffer[50];
	ICU_Data icu;
	//usart.USART2_init();

	while(1)
	{
		xEventGroupWaitBits(icuEvent, DEBUG_BIT, pdTRUE, pdFALSE, portMAX_DELAY);

		taskENTER_CRITICAL();
		icu = latestData;
		taskEXIT_CRITICAL();
		//xSemaphoreTake(usartMutex, portMAX_DELAY);

		usart.USART2_string("\r\n=========================================\r\n");

		usart.USART2_string("Patient = ");
		usart.USART2_string(name);

		usart.USART2_string("\n\rProblem = ");
		usart.USART2_string(problem);

		usart.USART2_string("\n\rICU No = ");
		usart.USART2_string(icuno);

		usart.USART2_string("\n\rBed No = ");
		usart.USART2_string(bedno);

		usart.USART2_string("\r\n-----------------------------------------\r\n");
		usart.USART2_string("HEALTH PARAMETERS\r\n");
		usart.USART2_string("-----------------------------------------\r\n");

		usart.USART2_string("Body temperature = ");
		sprintf(buffer, " %d\r\n", icu.temp);
		usart.USART2_string(buffer);

		usart.USART2_string("Oxygen in Blood = ");
		sprintf(buffer, " %d\r\n", icu.spo2);
		usart.USART2_string(buffer);

		usart.USART2_string("Heart rate = ");
		sprintf(buffer, " %d\r\n", icu.hr);
		usart.USART2_string(buffer);

		if(icu.alertLevel == 3)
		{
			usart.USART2_string(" \r\nEMERGENCY ALERT!! ");

			if(icu.temp > 104 || icu.temp < 82 )
			{
				usart.USART2_string("\r\n Body temperature is abnormal ");
			}

			if(icu.spo2 <90)
			{
				usart.USART2_string(" \r\nOxygen rate is abnormal ");
			}

			if((icu.hr <50 )||(icu.hr > 120))
			{
				usart.USART2_string(" \r\nHeart rate of patient is abnormal ");
			}

			usart.USART2_string(" \r\nCHECK THE PATIENT ");
		}

		else if(icu.alertLevel == 2)
		{
			usart.USART2_string(" \r\nWARNING ALERT!! ");

			if(icu.temp > 100 && icu.temp <=104 )
			{
				usart.USART2_string("\r\n Body temperature is varying ");
			}

			if(icu.spo2 <95)
			{
				usart.USART2_string(" \r\nOxygen rate is varying ");
			}

			if((icu.hr <60 )||(icu.hr > 100))
			{
				usart.USART2_string(" \r\nHeart rate of patient is varying ");
			}

			usart.USART2_string(" \r\nCHECK THE PATIENT ");
		}
		else
		{
			usart.USART2_string(" \r\n Everything is fine ");
		}

		usart.USART2_string("\r\n=========================================\r\n");

		//xSemaphoreGive(usartMutex);

		vTaskDelay(pdMS_TO_TICKS(500));

	}
}

