#include <cstdint>
#include "stm32f405xx.h"


enum class led : uint8_t
{
    GREEN  = 12,
    ORANGE = 13,
    RED    = 14,
    BLUE   = 15,
};



class GPIOClockGuard
{
public:
    GPIOClockGuard()
    {
        RCC->AHB1ENR |= (1U << 3); // GPIOD
        RCC->AHB1ENR |= (1U << 0); // GPIOA

    }

    ~GPIOClockGuard()
    {
    RCC->AHB1ENR &= ~(1U << 3); // GPIOD
    RCC->AHB1ENR &= ~(1U << 0); // GPIOA

    }
};



class GPIO
{
public:
    static void set_output(volatile std::uint32_t& moder, uint8_t pin)
    {
        moder &= ~(3U << (pin * 2));
        moder |=  (1U << (pin * 2));
    }

    static void set_input(volatile std::uint32_t& moder, uint8_t pin)
    {
        moder &= ~(3U << (pin * 2));
    }


    static void toggle(volatile std::uint32_t & ODR, led pin)
    {
        uint8_t p = static_cast<uint8_t>(pin);

        ODR ^=(1U<<p);
    }

    static bool read(volatile uint32_t &IDR, uint8_t pin)
    {
        return (IDR & (1U << pin)) != 0;
    }
};

void delay()
{
    for (volatile uint32_t i = 0; i < 100000; ++i);
}

int main()
{
    GPIOClockGuard obj;

    constexpr uint8_t SW =0;


    GPIO::set_output(GPIOD->MODER, static_cast<uint8_t>(led::GREEN));
    GPIO::set_output(GPIOD->MODER, static_cast<uint8_t>(led::ORANGE));
    GPIO::set_output(GPIOD->MODER, static_cast<uint8_t>(led::RED));
    GPIO::set_output(GPIOD->MODER, static_cast<uint8_t>(led::BLUE));


    GPIO::set_input(GPIOA->MODER, SW);

    while (true)
    {

        if (GPIO::read(GPIOA->IDR,SW))
        {
            break;
        }

        GPIO::toggle(GPIOD,led::GREEN);
        GPIO::toggle(GPIOD,led::ORANGE);
        GPIO::toggle(GPIOD,led::RED);
        GPIO::toggle(GPIOD,led::BLUE);
        delay();
    }
}
